{
  "name": "toronto-election-turnout-map",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive map viewer for Toronto municipal, provincial, and federal polling-division turnout datasets.",
  "scripts": {
    "build:data": "python3 elections/scripts/build_election_datasets.py",
    "build:census-profile": "python3 census/scripts/build_census_profile_tables.py",
    "build:census-map": "python3 census/scripts/build_census_profile_tables.py && python3 census/scripts/build_census_geography_viewer_data.py && python3 census/scripts/build_census_profile_tables.py",
    "build:interpolation-map": "python3 interpolation/scripts/build_map_data.py",
    "start": "node elections/viewer/server.js",
    "serve": "node elections/viewer/server.js",
    "start:census": "node census/viewer/server.js",
    "start:interpolation": "node interpolation/viewer/server.js"
  },
  "dependencies": {}
}
